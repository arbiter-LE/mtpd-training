{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.arbiterle.com" }],
      "destination": "https://arbiterle.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/privacy-policy",
      "has": [{ "type": "host", "value": "arbiterle.com" }],
      "destination": "/Marketing/privacy-policy.html"
    },
    {
      "source": "/onboarding/start-4872",
      "has": [{ "type": "host", "value": "arbiterle.com" }],
      "destination": "/Marketing/onboarding.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "arbiterle.com" }],
      "destination": "/Marketing/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
